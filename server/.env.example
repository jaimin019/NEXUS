# MongoDB Atlas connection string (must include username, password, and cluster URI)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0

# Groq API key for ORACLE, CHRONICLE, and SpectraSync LLM operations (llama-3.3-70b-versatile)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Upstash Redis connection parameters for Bull background queue (TLS required)
UPSTASH_REDIS_URL=rediss://default:token@host.upstash.io:6379
UPSTASH_REDIS_TOKEN=your_upstash_redis_token
UPSTASH_REDIS_HOST=your_upstash_redis_host.upstash.io
UPSTASH_REDIS_PORT=6379

# Server configuration
PORT=5001
NODE_ENV=development
