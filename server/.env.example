# MongoDB Atlas connection string — get from Atlas Dashboard > Connect > Drivers
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0

# Groq API key — get free at console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Upstash Redis — get from upstash.com > Create Database > REST API
UPSTASH_REDIS_URL=rediss://default:token@host.upstash.io:6379
UPSTASH_REDIS_TOKEN=your_upstash_redis_token
UPSTASH_REDIS_HOST=your_upstash_redis_host.upstash.io
UPSTASH_REDIS_PORT=6379

# JWT secret — any random 32+ character string
JWT_SECRET=nexus_secret_key_minimum_32_chars_long

PORT=5001 # 5001 recommended on macOS (port 5000 is used by AirPlay Receiver)
NODE_ENV=development
